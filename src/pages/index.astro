<style is:global>
  .starwind-tooltip-content > svg {
    display: none !important;
  }

  html, body {
    background-color: #010409;
    margin: 0;
    padding: 0;
    overflow-x: hidden; 
    width: 100%;
    position: relative;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  body::-webkit-scrollbar {
    display: none;
  }

  .bg-fixed-layer {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0; 
    pointer-events: none;
    background-image: 
      radial-gradient(circle at 0% 0%, rgba(13, 26, 26, 0.45) 0%, transparent 50%),
      radial-gradient(circle at 100% 40%, rgba(13, 26, 26, 0.35) 0%, transparent 50%),
      radial-gradient(circle at 15% 90%, rgba(13, 26, 26, 0.25) 0%, transparent 50%),
      radial-gradient(circle at 85% 95%, rgba(20, 20, 40, 0.25) 0%, transparent 40%),
      radial-gradient(circle at 50% 50%, rgba(10, 20, 30, 0.15) 0%, transparent 60%);
  }

  .bg-midnight {
    background: linear-gradient(135deg, #000000 0%, #0f172a 50%, #1e1b4b 100%);
    background-attachment: fixed;
    min-height: 100vh;
  }

  html {
    scroll-behavior: smooth;
  }
</style>
