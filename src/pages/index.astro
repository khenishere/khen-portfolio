      <div class="pt-10 w-full max-w-screen-2xl px-12 md:px-20 relative">
        <Carousel opts={{ align: "start", loop: true }} class="w-full">
          <CarouselContent class="-ml-2 md:-ml-4">
            {
              myVideos.map((video) => (
                <CarouselItem class="pl-2 md:pl-4 basis-[90%] sm:basis-1/2 md:basis-1/3 lg:basis-1/4">
                  <div class="p-1">
                     <Video 
                        src={video.src}
                        title={video.title}
                        class="aspect-[9/16] w-full rounded-2xl border border-white/10 shadow-lg"
                     />
                  </div>
                </CarouselItem>
              ))
            }
