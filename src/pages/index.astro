          <!-- Controls are now forced visible with flex -->
          <CarouselPrevious class="flex -left-8 md:-left-12" />
          <CarouselNext class="flex -right-8 md:-right-12" />
        </Carousel>
      </div>

      <div class="mt-20 mb-20">
        <img src="/logo.png" alt="khenishere logo" class="size-16 select-none pointer-events-none">
      </div>
    </section>

  
